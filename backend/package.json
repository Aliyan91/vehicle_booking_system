{
  "name": "vehicle-booking-backend",
  "version": "1.0.0",
  "type": "module",
  "description": "Rent-a-car vehicle booking backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node seed.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "db:reset": "prisma migrate reset --force && npm run seed"
  },
  "dependencies": {
    "@prisma/client": "6.19",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^7.5.2"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "nodemon": "^3.0.1",
    "prisma": "6.19"
  }
}
